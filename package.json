    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.2.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
